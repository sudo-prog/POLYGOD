# POLYGOD - Polymarket AI Trading Agent
# Copy to .env and fill in your keys for full functionality

# News API key from https://newsapi.org
NEWS_API_KEY=your_news_api_key

# Database URL (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./polymarket.db

# CORS origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Backend server settings
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Polymarket API key
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_SECRET=your_polymarket_secret
POLYMARKET_PASSPHRASE=your_polymarket_passphrase

# AI Agents
GEMINI_API_KEY=your_gemini_api_key
TAVILY_API_KEY=your_tavily_api_key
GROK_API_KEY=your_grok_api_key_here   # ← GET FREE KEY AT https://console.x.ai/

# POLYGOD Configuration
POLYGOD_MODE=0
MEM0_CONFIG={"provider": "qdrant", "vector_store": {"url": "http://qdrant:6333"}}

# Network Configuration (optional)
# FORCE_IPV4=true  # Set to true to force IPv4 DNS resolution (helps in some Docker setups)

# Database Configuration (optional)
# ALLOW_IN_MEMORY_DB_FALLBACK=false  # Set to true to allow in-memory DB fallback on init failure (dev only)

# Security Configuration
# POLYGOD_ADMIN_TOKEN=your_secure_admin_token  # Required for /polygod/switch-mode endpoint

# Dockerfile.backend for POLYGOD backend service
FROM python:3.12-slim

WORKDIR /app

# Install uv
RUN pip install uv

# Copy pyproject.toml and lockfile
COPY pyproject.toml uv.lock ./

# Install dependencies
RUN uv sync --frozen --no-install-project

# Copy source code
COPY . .

# Run alembic upgrade then start uvicorn
ENTRYPOINT ["sh", "-c", "uv run alembic upgrade head && uv run uvicorn src.backend.main:app --host 0.0.0.0 --port 8000"]
